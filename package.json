{
  "name": "liftpictures-mobile-app",
  "main": "index.js",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "build:web": "expo export --platform web",
    "lint": "expo lint",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "build:ios:preflight": "npx eas-cli build --platform ios --profile preflight-ios --non-interactive --wait",
    "build:ios:testflight": "npx eas-cli build --platform ios --profile testflight",
    "release:ios:testflight": "npx eas-cli build --platform ios --profile testflight --auto-submit --non-interactive --wait",
    "testflight": "npx eas-cli build --platform ios --profile testflight --auto-submit",
    "flighttest": "npx eas-cli build --platform ios --profile production --auto-submit",
    "submit:ios": "npx eas-cli submit --platform ios --latest"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.39.0",
    "expo": "~53.0.27",
    "expo-auth-session": "~6.2.1",
    "expo-av": "~15.1.7",
    "expo-blur": "~14.1.3",
    "expo-camera": "~16.1.5",
    "expo-constants": "~17.1.3",
    "expo-crypto": "~14.1.3",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.3",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.3",
    "expo-linking": "~7.1.3",
    "expo-media-library": "~17.1.7",
    "expo-router": "~5.1.11",
    "expo-splash-screen": "~0.30.6",
    "expo-status-bar": "~2.2.2",
    "expo-symbols": "~0.4.3",
    "expo-system-ui": "~5.0.5",
    "expo-web-browser": "~14.2.0",
    "i18next": "^25.8.0",
    "lucide-react-native": "^0.475.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "^16.5.3",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.0.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~9.2.0",
    "typescript": "~5.8.3"
  }
}
