{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preflight-ios": {
      "distribution": "internal",
      "environment": "production"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production"
    },
    "testflight": {
      "autoIncrement": true,
      "environment": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6759715172"
      }
    },
    "testflight": {
      "ios": {
        "ascAppId": "6759715172"
      }
    }
  }
}
